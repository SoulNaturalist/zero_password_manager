<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config — CWE-311 mitigation.

  - Clears all cleartext (HTTP) traffic in production builds.
  - Trust system CAs only (no user-installed CAs that could enable MITM).
  - Overrides for debug builds allow HTTP to local dev servers only.
-->
<network-security-config>

    <!-- Production: HTTPS only, system CAs only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow HTTP to localhost in debug builds only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
