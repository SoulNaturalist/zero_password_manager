# ==============================================================================
# ZERO PASSWORD MANAGER - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in the values.
# All MANDATORY variables must be set for the server to start.

# ------------------------------------------------------------------------------
# 1. MANDATORY SECURITY KEYS
# ------------------------------------------------------------------------------

# JWT Secret: Required for token signing. Use a long random string (min 64 chars).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# Seed Phrase Key: Used for encrypting sensitive data in the database.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SEED_PHRASE_KEY=

# TOTP Master Key: Base64 encoded 32-byte key for TOTP encryption.
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TOTP_MASTER_KEY=

# Device Secret: Secret for device fingerprinting HMAC.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DEVICE_SECRET=


# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------

# Database URL: Connection string (PostgreSQL, SQLite, etc.)
# Examples: 
#   SQLite: sqlite:///./zero_vault.db
#   PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./zero_vault.db


# ------------------------------------------------------------------------------
# 3. SERVER & ENVIRONMENT
# ------------------------------------------------------------------------------

# Environment: development, staging, production
ENVIRONMENT=development

# Core server settings
PROJECT_NAME="Zero Vault API"
PORT=3000


# ------------------------------------------------------------------------------
# 4. AUTH & SESSIONS
# ------------------------------------------------------------------------------

# Comma-separated list of actions requiring OTP: login, vault_read, vault_write, audit_read
PERMISSIONS_OTP_LIST=login,vault_write

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30


# ------------------------------------------------------------------------------
# 5. SECURITY POLICY
# ------------------------------------------------------------------------------

# Brute-force protection
MAX_FAILED_OTP_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15

# System maintenance
BLOCK_CLEANUP_INTERVAL_HOURS=1
MAX_PASSWORDS_PER_USER=1000


# ------------------------------------------------------------------------------
# 6. EXTERNAL INTEGRATIONS (OPTIONAL)
# ------------------------------------------------------------------------------

# Telegram Security Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ------------------------------------------------------------------------------
# 7. WEBAUTHN / FIDO2 / CORS
# ------------------------------------------------------------------------------

# Relying Party ID (usually your domain)
RP_ID=localhost
RP_NAME="Zero Password Manager"

# Expected origin for WebAuthn (e.g., http://localhost:3000)
EXPECTED_ORIGIN=http://localhost:3000

# Comma-separated list of additional allowed origins for WebAuthn
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000

# CORS: Comma-separated list of allowed origins (or * for any)
ALLOWED_ORIGINS=http://localhost:3000

# Security networking
WHITELIST_IPS=127.0.0.1,::1
TRUSTED_PROXY_RANGES=127.0.0.1,::1
